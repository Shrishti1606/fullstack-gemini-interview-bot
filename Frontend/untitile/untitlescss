.home{
    width: 100%;
    min-height: 100vh;

    display: flex;
    justify-content: center;
    align-items: center;

    .interview-input-group{
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        min-width: 600px;
        min-height: 500px;
    }

    .input-group:has(textarea){
        height: 100%;
    }

    textarea{
        height: 100%;
        width: 100%;
        padding-block: 0.75rem;
        padding-inline: 1rem;
        font-size: 16px;
        border: none;
        outline: none;
        border-radius: 0.5rem;
        background-color: #16142A;
        color: #E5E7EB;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        resize: none;
    }

    .left{
        align-self: stretch;
        width: 50%;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .file-label{
        background-color: #1F1C38;
        border: 1px dashed #3A3560;
        color: #E5E7EB;
        padding: 14px;
        cursor: pointer;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .file-label:hover {
        background-color: #26224A;
        border-color: #8B5CF6;
    }

    .right{
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        gap: 1rem;
        width: 50%;
        align-self: stretch;
    }

}